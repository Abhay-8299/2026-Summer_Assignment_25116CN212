#include<stdio.h>
int main ()
{ int i,n,prime=1;
    printf("Enter a number\t");
    scanf("%d",&n);
    for (i=2; i<=n/2; i++)
    { if(n%i==0)
      { prime=0;
       break;
      }
    }
   if(prime==1)
    printf("%d is a Prime Number",n);
    else
    printf("%d is not a Prime Number",n);

    return 0;
}
