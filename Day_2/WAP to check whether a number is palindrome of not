#include<stdio.h>
int main()
{
    int n,d,rev=0,temp;
    printf("Enter a number");
    scanf("%d",&n);
    temp=n;
    while(n>0)
    {  d=n%10;
      rev=rev*10+d;
      n=n/10;
    }
    printf("Reverse is = %d\n",rev);
    if(temp==rev)
    printf("The Entered Number is a Palindrome Number");
    else
    printf("The Entered Number is not a Palindrome Number");
    return 0;
}
