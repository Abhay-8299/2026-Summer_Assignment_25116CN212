#include<stdio.h>
int reverse(int);
int main()
{
    int n,result;
    printf("Enter a number\t");
    scanf("%d",&n);
        result=reverse(n);
        printf("The reverse number is %d ",result);
    
    return 0;
}
int reverse(int n)
{ int d ,rev=0;
    while(n>0)
    
{    d=n%10;
    rev=rev*10+d;
    n=n/10;
}
   
   return(rev);
}
