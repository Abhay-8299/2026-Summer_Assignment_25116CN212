#include<stdio.h>
int factorial(int);
int main()
{
    int n,fact;
    printf("Enter a number\t");
    scanf("%d",&n);
    if(n<0)
    {
        printf("Factorial of negative numbers is not defined");
    }
    else
    {
        fact=factorial(n);
        printf("The factorial is %d ",fact);
    }
    return 0;
}
int factorial(int n)
{
    int i,f=1;
    for(i=1;i<=n;i++)
   { f=f*i;
   }
   return(f);
}
