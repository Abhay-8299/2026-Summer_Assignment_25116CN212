#include<stdio.h>
int main()
{
    int n,a=0,b=1,nthTerm;
    printf("Enter number of nth term\t");
    scanf("%d",&n);

    if(n==0||n==1)
    {
        printf("fib(%d):%d",n,n);
        return 0;
    }
    for(int i=2;i<=n;++i)
    {
        nthTerm=a+b;
        a=b;
        b=nthTerm; 
    }
    printf("fib(%d):%d",n,nthTerm);
    return 0;
}
